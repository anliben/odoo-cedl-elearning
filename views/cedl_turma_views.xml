<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="cedl_turma_view_list" model="ir.ui.view">
        <field name="name">cedl.turma.list</field>
        <field name="model">cedl.turma</field>
        <field name="arch" type="xml">
            <list string="Turmas">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="materia_ids" widget="many2many_tags"/>
                <field name="channel_count" string="Cursos"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="cedl_turma_view_form" model="ir.ui.view">
        <field name="name">cedl.turma.form</field>
        <field name="model">cedl.turma</field>
        <field name="arch" type="xml">
            <form string="Turma">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="ex.: 1º ano – 101"/></h1>
                    </div>
                    <group>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                    <notebook>
                        <page string="Matérias da turma" name="materias">
                            <field name="materia_ids" widget="many2many_tags"
                                   options="{'color_field': 'color', 'no_create_edit': True}"/>
                        </page>
                        <page string="Cursos" name="cursos">
                            <field name="channel_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="cedl_turma_view_search" model="ir.ui.view">
        <field name="name">cedl.turma.search</field>
        <field name="model">cedl.turma</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="materia_ids"/>
                <filter name="inactive" string="Arquivadas"
                        domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <record id="action_cedl_turma" model="ir.actions.act_window">
        <field name="name">Turmas</field>
        <field name="res_model">cedl.turma</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
