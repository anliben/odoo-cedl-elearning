<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="cedl_materia_view_list" model="ir.ui.view">
        <field name="name">cedl.materia.list</field>
        <field name="model">cedl.materia</field>
        <field name="arch" type="xml">
            <list string="Matérias">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="turma_ids" widget="many2many_tags"/>
                <field name="turma_count" string="Turmas"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="cedl_materia_view_form" model="ir.ui.view">
        <field name="name">cedl.materia.form</field>
        <field name="model">cedl.materia</field>
        <field name="arch" type="xml">
            <form string="Matéria">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="ex.: Matemática"/></h1>
                    </div>
                    <group>
                        <field name="sequence"/>
                        <field name="color" widget="color_picker"/>
                        <field name="active"/>
                    </group>
                    <notebook>
                        <page string="Turmas que têm esta matéria" name="turmas">
                            <field name="turma_ids" widget="many2many_tags"
                                   options="{'no_create_edit': True}"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="cedl_materia_view_search" model="ir.ui.view">
        <field name="name">cedl.materia.search</field>
        <field name="model">cedl.materia</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="turma_ids"/>
                <filter name="inactive" string="Arquivadas"
                        domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <record id="action_cedl_materia" model="ir.actions.act_window">
        <field name="name">Matérias</field>
        <field name="res_model">cedl.materia</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
