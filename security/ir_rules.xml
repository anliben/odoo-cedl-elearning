<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="rule_slide_channel_partner_professor_all" model="ir.rule">
        <field name="name">Matrículas: professor vê todas</field>
        <field name="model_id" ref="website_slides.model_slide_channel_partner"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_professor'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_slide_channel_partner_portal_self" model="ir.rule">
        <field name="name">Matrículas: aluno vê só as próprias</field>
        <field name="model_id" ref="website_slides.model_slide_channel_partner"/>
        <field name="domain_force">[('partner_id', '=', user.partner_id.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>
</odoo>
